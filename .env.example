# Database
DATABASE_URL=postgresql+asyncpg://theseus:theseus@localhost:5432/theseus

# Auth
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=480

# LLM (optional — system works without AI configured)
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# App
LOG_LEVEL=INFO
DEBUG=false

# Object storage (MinIO / S3-compatible)
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=theseus-assets
STORAGE_REGION=us-east-1
STORAGE_PRESIGN_TTL_SECONDS=3600
STORAGE_LOCAL_ROOT=./_asset_store
